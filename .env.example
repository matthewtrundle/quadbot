# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Redis (worker - ioredis)
REDIS_URL=redis://localhost:6379

# Redis (web - Upstash)
UPSTASH_REDIS_REST_URL=https://your-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key-here-64-chars

# Google OAuth (stubbed)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Better Auth
BETTER_AUTH_SECRET=your-auth-secret-here
BETTER_AUTH_BASE_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=re_your-resend-key
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# Google Ads (optional)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
WORKER_PORT=4000
